#!/usr/bin/env bash
# github-catalog - Unified CLI Entrypoint
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
export REPO_ROOT="$SCRIPT_DIR"

# Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

# Dependency Checks
for cmd in jq git; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo -e "${RED}ERROR: Required command '$cmd' is not installed.${NC}" >&2
    exit 1
  fi
done

usage() {
  cat <<EOF
${CYAN}github-catalog${NC} - Local, append-only Git repository catalog

Usage:
  ./github-catalog <command> [arguments...]

Commands:
  refresh <target>      Refresh inventory only (no catalog collection)
                        Target: <owner> or <owner>/<repo>
                        Flags: --private, --public, --all (default: all)

  sync <owner> [glob]   Fetch and snapshot repositories matching glob (default: '*')
                        Flags: 
                          --private, --public, --all (default: all)
                          --git-host HOST  SSH config Host alias (e.g. github-personal)
                          --ssh-key PATH   Private key for git operations (optional)
                          --refresh (Force GitHub API list update via gh)
                          --parallel N (default: 4)

  report <owner>        Generate pure-jq markdown report from JSONL data
                        Output: reports/<owner>/report-<timestamp>.md
                        Symlink: reports/<owner>/latest.md → newest report

  clean <owner|all>     Wipe cached data, reports, and logs for an owner (or 'all')
  test                  Run pure-Bash unit tests
  lint                  Run syntax checks and ShellCheck

Examples:
  ./github-catalog refresh qobeat
  ./github-catalog refresh qobeat/ados-proj --public
  ./github-catalog sync qobeat ados-proj --git-host github-personal
  ./github-catalog sync qobeat 'ados-*' --git-host github-personal --refresh
  ./github-catalog sync qobeat 'ados-*' --private --refresh
  ./github-catalog report qobeat
  ./github-catalog clean qobeat
EOF
}

glob_has_wildcards() {
  [[ "$1" == *[\*\?\[]* ]]
}

sync_needs_gh() {
  local owner="$1" glob="$2" refresh="$3" git_host="$4"
  (( refresh == 1 )) && return 0
  glob_has_wildcards "$glob" && return 0
  [[ -z "$git_host" ]] && return 0
  return 1
}

[[ $# -eq 0 ]] && { usage; exit 1; }

COMMAND="$1"
shift

case "$COMMAND" in
  refresh)
    [[ $# -eq 0 ]] && { echo -e "${RED}ERROR: 'refresh' requires a <owner> or <owner>/<repo> target.${NC}" >&2; exit 1; }
    TARGET="$1"; shift
    TYPE="all"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --private) TYPE="private"; shift ;;
        --public)  TYPE="public"; shift ;;
        --all)     TYPE="all"; shift ;;
        *) echo -e "${RED}ERROR: Unknown flag '$1'${NC}" >&2; exit 1 ;;
      esac
    done
    if ! command -v gh >/dev/null 2>&1; then
      echo -e "${RED}ERROR: GitHub CLI ('gh') is required to refresh inventory.${NC}" >&2
      exit 1
    fi
    echo -e "${CYAN}▶ Refreshing inventory for $TARGET [Type: $TYPE]${NC}"
    "$REPO_ROOT/scripts/github-catalog-refresh.sh" --target "$TARGET" --type "$TYPE"
    ;;

  sync)
    [[ $# -eq 0 ]] && { echo -e "${RED}ERROR: 'sync' requires an <owner> argument.${NC}" >&2; exit 1; }
    OWNER="$1"; shift
    GLOB="*"
    if [[ $# -gt 0 && ! "$1" =~ ^-- ]]; then
      GLOB="$1"; shift
    fi

    TYPE="all"
    REFRESH=0
    PARALLEL=4
    GIT_HOST="${GITHUB_CATALOG_GIT_HOST:-}"
    SSH_KEY="${GITHUB_CATALOG_SSH_KEY:-}"

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --private) TYPE="private"; shift ;;
        --public)  TYPE="public"; shift ;;
        --all)     TYPE="all"; shift ;;
        --git-host) GIT_HOST="${2:?--git-host requires a value}"; shift 2 ;;
        --ssh-key)  SSH_KEY="${2:?--ssh-key requires a value}"; shift 2 ;;
        --refresh) REFRESH=1; shift ;;
        --parallel) PARALLEL="${2:?--parallel requires a value}"; shift 2 ;;
        *) echo -e "${RED}ERROR: Unknown flag '$1'${NC}" >&2; exit 1 ;;
      esac
    done

    INVENTORY_FILE="$REPO_ROOT/data/$OWNER/user-repositories.jsonl"
    if sync_needs_gh "$OWNER" "$GLOB" "$REFRESH" "$GIT_HOST"; then
      if [[ ! -f "$INVENTORY_FILE" ]] || (( REFRESH == 1 )); then
        if ! command -v gh >/dev/null 2>&1; then
          echo -e "${RED}ERROR: GitHub CLI ('gh') is required to prefetch inventory (wildcard glob, --refresh, or first sync without --git-host).${NC}" >&2
          exit 1
        fi
      fi
    fi

    ARGS=(
      --owner "$OWNER"
      --repos "$GLOB"
      --type "$TYPE"
      --parallel "$PARALLEL"
    )
    (( REFRESH == 1 )) && ARGS+=(--refresh-repo-list)
    [[ -n "$GIT_HOST" ]] && ARGS+=(--git-host "$GIT_HOST")
    [[ -n "$SSH_KEY" ]] && ARGS+=(--ssh-key "$SSH_KEY")

    echo -e "${CYAN}▶ Starting sync for $OWNER ($GLOB) [Type: $TYPE]${NC}"
    "$REPO_ROOT/scripts/github-catalog-orchestrator.sh" "${ARGS[@]}"
    ;;

  report)
    [[ $# -eq 0 ]] && { echo -e "${RED}ERROR: 'report' requires an <owner> argument.${NC}" >&2; exit 1; }
    OWNER="$1"
    echo -e "${CYAN}▶ Generating report for $OWNER...${NC}"
    "$REPO_ROOT/scripts/github-catalog-report.sh" --owner "$OWNER"
    ;;

  clean)
    [[ $# -eq 0 ]] && { echo -e "${RED}ERROR: 'clean' requires an <owner> argument or 'all'.${NC}" >&2; exit 1; }
    TARGET="$1"
    if [[ "$TARGET" == "all" ]]; then
      rm -rf "$REPO_ROOT/data/"* "$REPO_ROOT/reports/"* "$REPO_ROOT/logs/"*
      echo -e "${GREEN}✓ Cleaned all data, reports, and logs.${NC}"
    else
      rm -rf "$REPO_ROOT/data/$TARGET" "$REPO_ROOT/reports/$TARGET"
      echo -e "${GREEN}✓ Cleaned data and reports for owner: $TARGET${NC}"
    fi
    ;;

  test)
    echo -e "${CYAN}▶ Running test suite...${NC}"
    "$REPO_ROOT/tests/test.sh"
    ;;

  lint)
    echo -e "${CYAN}▶ Running linters...${NC}"
    "$REPO_ROOT/tests/lint.sh"
    ;;

  *)
    usage
    exit 1
    ;;
esac